@startuml CREDENTIAL_ERD
hide circle
skinparam linetype ortho
title Credential & OAuth Manager - ERD

entity "User" as CO_User {
  *id : String <<PK>>
  --
  email : String <<UNIQUE>>
  name : String
}

entity "OAuthCredential" as CO_OAuthCredential {
  *id : String <<PK>>
  --
  userId : String <<FK:User.id>>
  provider : String
  service : String?
  notes : String?
  accessToken : Text
  refreshToken : Text?
  accessTokenExpiresAt : DateTime?
  refreshTokenExpiresAt : DateTime?
  scopes : String[]
  providerEmail : String?
  gmailHistoryId : String?
  gmailWatchExpiration : DateTime?
  createdAt : DateTime
  updatedAt : DateTime
  --
  UNIQUE(provider, service, userId)
}

entity "DiscordGuild" as CO_DiscordGuild {
  *id : String <<PK>>
  --
  credentialId : String <<FK:OAuthCredential.id>>
  guildId : String
  guildName : String?
  createdAt : DateTime
  updatedAt : DateTime
  --
  UNIQUE(credentialId, guildId)
}

CO_User ||--o{ CO_OAuthCredential : owns
CO_OAuthCredential ||--o{ CO_DiscordGuild : authorizes
@enduml


