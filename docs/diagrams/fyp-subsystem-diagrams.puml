' ============================================================
' 5) Workflow Execution System - ERD
' ============================================================
@startuml WORKFLOW_EXEC_ERD
hide circle
skinparam linetype ortho
title Workflow Execution System - ERD

entity "Workflow" as WE_Workflow {
  *id : String <<PK>>
  --
  nodes : Json
  edges : Json
  isActive : Boolean
}

entity "WorkflowExecution" as WE_WorkflowExecution {
  *id : String <<PK>>
  --
  workflowId : String <<FK:Workflow.id>>
  status : WorkflowExecutionStatus
  triggerType : TriggerType
  error : String?
  duration : Int?
