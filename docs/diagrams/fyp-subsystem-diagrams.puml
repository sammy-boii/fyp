}

WE_Workflow ||--o{ WE_WorkflowExecution : spawns
WE_WorkflowExecution ||--o{ WE_NodeExecution : records
@enduml


' ============================================================
' 6) Workflow Execution System - Class Diagram
' ============================================================
@startuml WORKFLOW_EXEC_CLASS
hide empty members
skinparam linetype ortho
left to right direction
skinparam ranksep 55
skinparam nodesep 35
title Workflow Execution System - Class Diagram

class WorkflowController <<module>> {
  +runWorkflow(context)
}

class SingleNodeController <<module>> {
  +executeSingleNode(context)
}

class WorkflowExecutor <<module>> {
  +executeWorkflowById(workflowId, triggerData, triggerType)
  -buildExecutionOrder(nodes, edges)
  -executeNode(node, executionId, nodeOutputs)
  -markDescendantsAsSkipped(nodeId, edges, skippedNodes)
}

class NodeExecutor <<module>> {
  +executeNodeLogic(node, config, triggerData, nodeOutputs)
}

class TriggerExecutor <<module>> {
  +executeTriggerNode(node, config, eventData)
  +isTriggerNode(actionId)
  +isManualTrigger(actionId)
  +isScheduledTrigger(actionId)
}

class ConditionExecutor <<module>> {
  +executeCondition(config, nodeOutputs)
}

class PlaceholderResolver <<module>> {
  +replacePlaceholdersInConfig(config, nodeOutputs)
  +buildNodeOutputsMap(nodeId, nodes, edges)
  +findPredecessorNodes(nodeId, edges)
}

class GmailExecutor <<module>>
class GoogleDriveExecutor <<module>>
class DiscordExecutor <<module>>
class AIExecutor <<module>>
class HTTPExecutor <<module>>
class ExecutionRepository <<prisma>>
class WebSocketEventBus <<module>>

WorkflowController -[hidden]down-> SingleNodeController
WorkflowExecutor -[hidden]down-> NodeExecutor
NodeExecutor -[hidden]down-> PlaceholderResolver
TriggerExecutor -[hidden]down-> ConditionExecutor
ConditionExecutor -[hidden]down-> GmailExecutor
GmailExecutor -[hidden]down-> GoogleDriveExecutor
GoogleDriveExecutor -[hidden]down-> DiscordExecutor
DiscordExecutor -[hidden]down-> AIExecutor
AIExecutor -[hidden]down-> HTTPExecutor
ExecutionRepository -[hidden]down-> WebSocketEventBus

WorkflowController -right-> WorkflowExecutor
SingleNodeController -right-> NodeExecutor
SingleNodeController -right-> PlaceholderResolver
SingleNodeController -right-> ExecutionRepository

WorkflowExecutor -right-> ExecutionRepository
WorkflowExecutor -right-> NodeExecutor
WorkflowExecutor -right-> PlaceholderResolver
WorkflowExecutor -right-> TriggerExecutor
WorkflowExecutor -right-> WebSocketEventBus : emits events

NodeExecutor -right-> TriggerExecutor
NodeExecutor -right-> ConditionExecutor
NodeExecutor -right-> GmailExecutor
NodeExecutor -right-> GoogleDriveExecutor
NodeExecutor -right-> DiscordExecutor
NodeExecutor -right-> AIExecutor
NodeExecutor -right-> HTTPExecutor
@enduml


