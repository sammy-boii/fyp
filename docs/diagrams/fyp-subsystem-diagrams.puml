' FYP Subsystem Diagram Pack
' 10 diagrams total: ERD + Class per subsystem
' Format: PlantUML (draw.io friendly)

' ============================================================
' 1) Identity & Access Management - ERD
' ============================================================
@startuml IAM_ERD
hide circle
skinparam linetype ortho
title Identity & Access Management - ERD

entity "User" as IAM_User {
  *id : String <<PK>>
  --
  name : String
  email : String <<UNIQUE>>
  password : String
  avatar : String?
  otp : String?
  otpExpiresAt : DateTime?
  createdAt : DateTime
  updatedAt : DateTime
}

entity "Workflow" as IAM_Workflow {
  *id : String <<PK>>
  --
  authorId : String <<FK:User.id>>
  name : String
  isActive : Boolean
}

entity "OAuthCredential" as IAM_OAuthCredential {
  *id : String <<PK>>
  --
  userId : String <<FK:User.id>>
  provider : String
  service : String?
  accessToken : Text
  createdAt : DateTime
}

IAM_User ||--o{ IAM_Workflow : dashboard_count
IAM_User ||--o{ IAM_OAuthCredential : dashboard_count
@enduml


' ============================================================
' 2) Identity & Access Management - Class Diagram
' ============================================================
@startuml IAM_CLASS
hide empty members
skinparam linetype ortho
left to right direction
skinparam ranksep 55
skinparam nodesep 35
title Identity & Access Management - Class Diagram

class AuthService <<module>> {
  +signUp(data)
  +login(data)
  +logout()
}

class UserProfileService <<module>> {
  +getProfile()
  +updateProfile(data)
  +changePassword(data)
  +resetPassword(data)
}

class PasswordResetService <<module>> {
  +sendResetOTP(email)
  +verifyResetOTP(email, otp)
}

class IdentityContextDAL <<module>> {
  +getCurrentUser()
}

class AuthMiddleware <<module>> {
  +authMiddleware(context, next)
}

class RouteGuardMiddleware <<module>> {
  +middleware(request)
}

class UserRepository <<prisma>>
class JwtProvider <<library>>
class PasswordHasher <<library>>

AuthService -[hidden]down-> UserProfileService
UserProfileService -[hidden]down-> PasswordResetService
IdentityContextDAL -[hidden]down-> AuthMiddleware
AuthMiddleware -[hidden]down-> RouteGuardMiddleware
UserRepository -[hidden]down-> PasswordHasher
PasswordHasher -[hidden]down-> JwtProvider

AuthService -right-> UserRepository
AuthService -right-> PasswordHasher
AuthService -right-> JwtProvider

UserProfileService -right-> IdentityContextDAL
UserProfileService -right-> UserRepository
UserProfileService -right-> PasswordHasher

PasswordResetService -right-> UserRepository
PasswordResetService -right-> JwtProvider

AuthMiddleware -right-> JwtProvider
AuthMiddleware -right-> UserRepository
RouteGuardMiddleware -right-> IdentityContextDAL : token presence gate
@enduml


